{
  "_meta": {
    "title": "顺序重组小游戏题库",
    "desc": "lines 按正确顺序书写,场景内洗牌展示,玩家按序点击还原。dev=代码执行顺序,test=测试流程顺序。每难度≥3题。"
  },
  "dev": [
    {
      "id": "sd1",
      "difficulty": "easy",
      "title": "把「读取用户」流程排对",
      "lines": [
        "接收请求参数 userId",
        "校验 userId 是否合法",
        "查询数据库取用户",
        "返回 JSON 结果"
      ],
      "explain": "先校验再查库:非法参数不该碰数据库。"
    },
    {
      "id": "sd2",
      "difficulty": "easy",
      "title": "排出正确的发布流程",
      "lines": [
        "本地跑通所有测试",
        "提交代码到主分支",
        "构建打包产物",
        "部署到线上环境"
      ],
      "explain": "测试→提交→构建→部署,顺序错一步都可能上线事故。"
    },
    {
      "id": "sd3",
      "difficulty": "easy",
      "title": "登录逻辑的正确顺序",
      "lines": [
        "接收手机号和验证码",
        "检查验证码是否过期",
        "比对验证码是否正确",
        "生成并返回登录态 token"
      ],
      "explain": "先看过期再比对,过期的码对了也不能放行。"
    },
    {
      "id": "sd4",
      "difficulty": "mid",
      "title": "缓存读取的正确姿势",
      "lines": [
        "先查缓存有没有",
        "缓存命中直接返回",
        "未命中再查数据库",
        "把结果写回缓存",
        "返回数据库结果"
      ],
      "explain": "Cache-Aside:先缓存后数据库,回写别忘了。"
    },
    {
      "id": "sd5",
      "difficulty": "mid",
      "title": "异常处理的执行顺序",
      "lines": [
        "打开数据库连接",
        "执行业务查询",
        "捕获并记录异常",
        "无论成败关闭连接",
        "向上抛出业务错误"
      ],
      "explain": "finally 关连接在抛错之前执行——资源必须先释放。"
    },
    {
      "id": "sd6",
      "difficulty": "mid",
      "title": "分页接口的处理链",
      "lines": [
        "解析 page 和 pageSize",
        "钳制 pageSize 上限",
        "计算 offset 偏移量",
        "带 limit 查询数据库",
        "返回数据和总条数"
      ],
      "explain": "不钳制 pageSize,一个 ?pageSize=99999 就能拖垮库。"
    },
    {
      "id": "sd7",
      "difficulty": "hard",
      "title": "事务转账的完整顺序",
      "lines": [
        "开启数据库事务",
        "锁定转出账户行",
        "校验余额是否充足",
        "扣减转出方余额",
        "增加转入方余额",
        "提交事务并释放锁"
      ],
      "explain": "先锁后查再改:不锁行,并发下余额校验形同虚设。"
    },
    {
      "id": "sd8",
      "difficulty": "hard",
      "title": "消息消费的可靠顺序",
      "lines": [
        "从队列拉取一条消息",
        "检查消息是否已处理过",
        "执行业务处理逻辑",
        "把消息标记为已处理",
        "向队列确认 ack"
      ],
      "explain": "先幂等检查再处理,ack 放最后——中途崩了消息还能重来。"
    },
    {
      "id": "sd9",
      "difficulty": "hard",
      "title": "灰度发布的正确节奏",
      "lines": [
        "部署新版本到灰度机器",
        "切 5% 流量进灰度",
        "观察错误率与延迟指标",
        "指标正常逐步放大流量",
        "全量后保留回滚通道"
      ],
      "explain": "灰度的意义就是小流量验证——一把梭全量等于裸奔。"
    }
  ],
  "test": [
    {
      "id": "st1",
      "difficulty": "easy",
      "title": "一条 bug 的标准生命周期",
