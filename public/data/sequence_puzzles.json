      "explain": "不能复现的 bug 单是开发的噩梦——先复现再提单。"
    },
    {
      "id": "st2",
      "difficulty": "easy",
      "title": "接手需求后的测试顺序",
      "lines": [
        "读需求文档划边界",
        "设计测试用例",
        "执行用例记录结果",
        "输出测试报告"
      ],
      "explain": "用例先于执行:边测边想等于漏测。"
    },
    {
      "id": "st3",
      "difficulty": "easy",
      "title": "冒烟测试的正确流程",
      "lines": [
        "确认提测包版本号",
        "部署到测试环境",
        "跑主流程冒烟用例",
        "冒烟通过才开始细测"
      ],
      "explain": "版本都对不上,测得再细也是白测。"
    },
    {
      "id": "st4",
      "difficulty": "mid",
      "title": "登录功能的用例优先级",
      "lines": [
        "正确账号密码能登录",
        "错误密码给出明确提示",
        "连续错 3 次触发锁定",
        "空输入被前端拦截",
        "过期验证码不能通过"
      ],
      "explain": "先保主流程(能登),再堵异常路径——优先级就是风险排序。"
    },
    {
      "id": "st5",
      "difficulty": "mid",
      "title": "复现偶现 bug 的套路",
      "lines": [
        "收集出现时的环境信息",
        "固定变量逐一排除",
        "找到稳定复现路径",
        "最小化复现步骤",
        "带日志和步骤提单"
      ],
      "explain": "偶现≠随机:固定变量排除法是复现的第一性原理。"
    },
    {
      "id": "st6",
      "difficulty": "mid",
      "title": "回归测试的正确范围",
      "lines": [
        "拿到本次改动清单",
        "分析改动影响的模块",
        "挑选关联用例集",
        "执行回归并盯新问题",
        "确认无回归后签字"
      ],
      "explain": "回归不是全量重测,是按影响面精准打击。"
    },
    {
      "id": "st7",
      "difficulty": "hard",
      "title": "线上事故的测试响应",
      "lines": [
        "确认事故现象和影响面",
        "在测试环境复现问题",
        "验证开发的止血方案",
        "回归验证修复版本",
        "补一条防回归用例"
      ],
      "explain": "最后一步最关键:每个线上事故都该沉淀成一条用例。"
    },
    {
      "id": "st8",
      "difficulty": "hard",
      "title": "性能测试的完整链路",
      "lines": [
        "明确性能指标基线",
        "准备等比例测试数据",
        "阶梯加压观察拐点",
        "定位瓶颈出具报告",
        "优化后复测对比基线"
      ],
      "explain": "没有基线的压测只是烧机器——先定标准再施压。"
    },
    {
      "id": "st9",
      "difficulty": "hard",
      "title": "验收签字前的检查单",
      "lines": [
        "全部用例执行完毕",
        "遗留 bug 均有结论",
        "核对需求验收标准",
        "确认回滚方案可用",
        "在验收报告上签字"
      ],
      "explain": "签字=背书:每一项都过了,名字才写得踏实。"
    }
